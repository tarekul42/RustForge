# Server
APP_SERVER__HOST=0.0.0.0
APP_SERVER__PORT=5000

# Database (required)
APP_DATABASE__URL=postgres://workshop:workshop_secret@localhost:5432/skill_workshop
APP_DATABASE__MAX_CONNECTIONS=10
APP_DATABASE__STATEMENT_TIMEOUT_SECS=30

# Observability
APP_OBSERVABILITY__LOG_LEVEL=info
APP_OBSERVABILITY__METRICS_PORT=5001
APP_OBSERVABILITY__METRICS_API_KEY=change-me-to-a-random-secret
APP_OBSERVABILITY__OTLP_ENDPOINT=
APP_OBSERVABILITY__TRACE_SAMPLE_RATIO=1.0

# Environment
APP_ENV=development
